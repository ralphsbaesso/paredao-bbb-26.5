# Ambiente de desenvolvimento do projeto inteiro para `docker compose up`
# (ou `task up`) a partir da raiz — ver compose.yaml.
# Copie para `.env` e ajuste conforme necessário:  cp .env.example .env
# Apenas defaults de desenvolvimento local — nunca coloque segredos reais aqui.

# --- PostgreSQL (serviço: db) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=backend_development

# --- Rails app (serviço: app) ---
# String de conexão apontando para o serviço `db` pela rede do Compose.
# Rails mescla DATABASE_URL sobre config/database.yml.
DATABASE_URL=postgres://postgres:postgres@db:5432/backend_development

# Redis, alcançado no serviço `redis` pela rede do Compose.
REDIS_URL=redis://redis:6379/0

# Porta do host em que a API é publicada (host:container -> ${APP_PORT}:3000).
APP_PORT=3000

# Tamanho do pool de threads da Puma / ActiveRecord.
# Bump para 10 dá mais vazão sob teste de carga (o pool do Postgres precisa
# comportar threads x workers).
RAILS_MAX_THREADS=10

# --- Frontend (serviço: frontend, Nuxt 4 SSR) ---
# Porta do host em que o Nuxt é publicado (host:container -> ${FRONTEND_PORT}:3000).
FRONTEND_PORT=3001

# URLs base da API injetadas no frontend em runtime (nunca hardcoded no build).
# Pública: usada pelo browser — precisa ser alcançável do host (localhost).
# Interna: usada no SSR — o servidor Nuxt alcança o backend pela rede do Compose.
NUXT_PUBLIC_API_BASE=http://localhost:3000
NUXT_API_BASE_INTERNAL=http://app:3000

# --- Observabilidade (serviços: prometheus, grafana — task 009) ---
# Porta do host em que o Prometheus é publicado (UI em http://localhost:9090).
PROMETHEUS_PORT=9090

# Porta do host em que o Grafana é publicado (host:container -> ${GRAFANA_PORT}:3000).
# UI em http://localhost:3002 (3000 é a API, 3001 o frontend).
GRAFANA_PORT=3002

# Credenciais do admin do Grafana (apenas desenvolvimento local).
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

ADMIN_EMAIL=admin@bbb.com
ADMIN_PASSWORD=123456
