#!/bin/bash -e

# Development entrypoint (see Dockerfile.dev / compose.yaml).
#
# Remove a stale Puma pidfile left behind by a hard container stop, then make
# sure the database exists and is migrated before handing off to the command.

if [ -f tmp/pids/server.pid ]; then
  rm -f tmp/pids/server.pid
fi

# Bundler safety net: the image bakes gems in, but if the bind-mounted Gemfile
# has drifted (new gem added on the host), install it before booting.
if ! bundle check > /dev/null 2>&1; then
  echo 'Gemfile changed — running bundle install...'
  bundle install
fi

# Create the database if needed and run any pending migrations.
./bin/rails db:prepare

exec "${@}"
