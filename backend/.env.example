# Development environment for `docker compose up` (see compose.yaml).
# Copy to `.env` and adjust as needed:  cp .env.example .env
# These are local development defaults only — never put real secrets here.

# --- PostgreSQL (service: db) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=backend_development

# --- Rails app (service: app) ---
# Connection string pointing at the `db` service over the Compose network.
# Rails merges DATABASE_URL on top of config/database.yml.
DATABASE_URL=postgres://postgres:postgres@db:5432/backend_development

# Redis, reached at the `redis` service over the Compose network.
REDIS_URL=redis://redis:6379/0

# Host port the Rails app is published on (host:container -> ${APP_PORT}:3000).
APP_PORT=3000

# Puma / ActiveRecord thread pool size.
RAILS_MAX_THREADS=5
