# URLs base da API do backend (injetadas em runtime, nunca no build).
# Rodando o frontend fora do Docker (yarn dev), ambas apontam para a API local.
# No Compose elas divergem: browser usa a pública, o SSR usa a interna (`app`).
NUXT_PUBLIC_API_BASE=http://localhost:3000
NUXT_API_BASE_INTERNAL=http://localhost:3000

# URLs dos serviços de observabilidade linkados no painel admin (browser).
NUXT_PUBLIC_GRAFANA_URL=http://localhost:3002
NUXT_PUBLIC_PROMETHEUS_URL=http://localhost:9090
