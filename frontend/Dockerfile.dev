# syntax=docker/dockerfile:1
# check=error=true

# Imagem de DESENVOLVIMENTO do frontend Nuxt 4 (SSR, hot-reload).
#
# Diferente de ./Dockerfile (produção multi-stage, roda o .output/ como non-root):
# aqui instalamos TODAS as dependências e rodamos `yarn dev`, contando com o
# bind-mount do código-fonte no compose.yaml da raiz para hot-reload.

# Base Debian/glibc (node:22-slim), NÃO Alpine/musl — evita falha dos binários
# nativos do @tailwindcss/oxide e do Rollup/oxc.
FROM node:22-slim
WORKDIR /app

# Yarn 4 (Berry) habilitado via Corepack; versão fixada por packageManager.
ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0
RUN corepack enable

# Instala dependências primeiro para cachear esta layer entre mudanças de código.
COPY package.json yarn.lock .yarnrc.yml ./
RUN yarn install --immutable

# Fallback para `docker run`; em runtime o compose bind-monta o código sobre isto.
COPY . .

# Nuxt precisa escutar em 0.0.0.0 para ser acessível fora do container.
ENV HOST=0.0.0.0 \
    PORT=3000
EXPOSE 3000
CMD ["yarn", "dev"]
