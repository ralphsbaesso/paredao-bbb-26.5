{
  "uid": "paredao-api-health",
  "title": "Paredão · Saúde da API",
  "tags": ["paredao", "api"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requisições/s (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(rails_requests_total[1m]))" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Taxa de erros 5xx (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 2, "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "100 * sum(rate(rails_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(rails_requests_total[5m])), 1)" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Requisições/s por rota",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (controller, action) (rate(rails_requests_total[1m]))", "legendFormat": "{{controller}}#{{action}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latência das requisições (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(rails_request_duration_seconds_bucket[5m])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(rails_request_duration_seconds_bucket[5m])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(rails_request_duration_seconds_bucket[5m])))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Taxa de erros por rota (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "100 * sum by (controller, action) (rate(rails_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum by (controller, action) (rate(rails_requests_total[5m])), 1)", "legendFormat": "{{controller}}#{{action}}" }
      ]
    }
  ]
}
